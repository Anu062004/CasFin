ARBITRUM_SEPOLIA_RPC_URL=https://arbitrum-sepolia.infura.io/v3/your-infura-project-id
# Wallet private key for the deployer / keeper account
PRIVATE_KEY=your_private_key_here
# Optional. Falls back to PRIVATE_KEY when omitted.
FHENIX_PRIVATE_KEY=your_fhenix_private_key_here
# Arbiscan API key used by the Hardhat verify step
ARBISCAN_API_KEY=your_arbiscan_api_key
FHENIX_RPC_URL=https://api.helium.fhenix.zone
# Set true only for local testing if you want the manual randomness router instead of Chainlink VRF
FORCE_MANUAL_ROUTER=false
# Chainlink VRF V2.5 coordinator address for the target network
VRF_COORDINATOR_ADDRESS=0x5CE8D5A2BC84beb22a398CCA51996F7930313D61
# Chainlink VRF key hash / gas lane for the subscription
VRF_KEY_HASH=0xyour_vrf_key_hash
# Chainlink VRF subscription id that funds randomness requests
VRF_SUBSCRIPTION_ID=0
# Number of block confirmations before fulfillment
VRF_REQUEST_CONFIRMATIONS=3
# Callback gas limit for the VRF consumer
VRF_CALLBACK_GAS_LIMIT=250000
# Number of random words to request
VRF_NUM_WORDS=1
# Set true to pay VRF fees in native gas token when supported
VRF_NATIVE_PAYMENT=true

# Existing encrypted casino vault used by the encrypted prediction market
ENCRYPTED_CASINO_VAULT_ADDRESS=0x0000000000000000000000000000000000000000
# Encrypted prediction factory deployed by scripts/deployFhenixPrediction.ts
ENCRYPTED_PREDICTION_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
# Optional comma-separated list of encrypted prediction markets for the keeper
ENCRYPTED_MARKET_ADDRESSES=

# Neon Postgres (Vercel Storage)
# Pooled connection (recommended for most uses — API routes, server components)
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT-pooler.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require
# Direct connection (for schema migrations / DDL)
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT.us-east-1.aws.neon.tech/neondb?sslmode=require
PGHOST=ep-YOUR-ENDPOINT-pooler.us-east-1.aws.neon.tech
PGUSER=neondb_owner
PGDATABASE=neondb
PGPASSWORD=YOUR_PASSWORD
