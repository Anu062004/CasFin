{
  "name": "casfin",
  "version": "0.1.0",
  "private": true,
  "description": "CasFin is an encrypted casino and prediction market protocol deployed on Arbitrum Sepolia.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:casino": "hardhat run scripts/deployCasinoStage.ts --network arbitrumSepolia",
    "deploy:prediction": "hardhat run scripts/deployPredictionStage.ts --network arbitrumSepolia",
    "deploy:all": "hardhat run scripts/deployAllStages.ts --network arbitrumSepolia",
    "deploy:full": "hardhat run scripts/deployFullStack.ts --network arbitrumSepolia",
    "redeploy:fhe-games": "hardhat run scripts/redeployFheGames.ts --network arbitrumSepolia",
    "authorize:games": "hardhat run scripts/authorizeGames.ts --network arbitrumSepolia",
    "verify": "hardhat verify --network arbitrumSepolia",
    "keeper:start": "ts-node --transpile-only keeper/index.ts",
    "keeper:start:fhe": "ts-node --transpile-only keeper/fhe-keeper.ts",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:start": "npm --prefix frontend run start",
    "prepare": "node scripts/setupHusky.js"
  },
  "devDependencies": {
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.5.2",
    "chai": "^4.5.0",
    "dotenv": "^16.5.0",
    "ethers": "^6.13.5",
    "hardhat": "^2.24.2",
    "hardhat-abi-exporter": "^2.11.0",
    "husky": "^9.1.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "ioredis": "^5.10.1"
  }
}
