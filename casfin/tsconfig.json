{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleDetection": "force",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["node", "mocha"]
  },
  "include": ["hardhat.config.ts", "scripts/**/*.ts", "keeper/**/*.ts", "test/**/*.ts"],
  "exclude": ["artifacts", "cache", "frontend", "node_modules"]
}
