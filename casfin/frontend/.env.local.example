# ============================================
# REQUIRED: Alchemy RPC URLs for Arbitrum Sepolia
# Get keys from: dashboard.alchemy.com
# Create app with: Chain=Arbitrum, Network=Arbitrum Sepolia
# MUST have NEXT_PUBLIC_ prefix to work in browser
# MUST also be added to Vercel → Settings → Environment Variables
# ============================================
NEXT_PUBLIC_ALCHEMY_ARB_SEPOLIA_RPC_1=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY_1
NEXT_PUBLIC_ALCHEMY_ARB_SEPOLIA_RPC_2=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY_2
NEXT_PUBLIC_ALCHEMY_ARB_SEPOLIA_RPC_3=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY_3
NEXT_PUBLIC_ALCHEMY_ARB_SEPOLIA_RPC_4=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY_4
